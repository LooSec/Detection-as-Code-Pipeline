{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Detection Rule",
  "type": "object",
  "required": ["id", "name", "description", "severity", "mitre", "data_source", "logic"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(AWS|WIN|LIN)-\\d{3}$"
    },
    "name": {
      "type": "string",
      "minLength": 5,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "mitre": {
      "type": "object",
      "required": ["tactic", "technique"],
      "properties": {
        "tactic": {
          "type": "string",
          "enum": [
            "reconnaissance", "resource-development", "initial-access",
            "execution", "persistence", "privilege-escalation",
            "defense-evasion", "credential-access", "discovery",
            "lateral-movement", "collection", "command-and-control",
            "exfiltration", "impact"
          ]
        },
        "technique": {
          "type": "string",
          "pattern": "^T\\d{4}$"
        },
        "subtechnique": {
          "type": "string",
          "pattern": "^T\\d{4}\\.\\d{3}$"
        }
      }
    },
    "data_source": {
      "type": "string",
      "enum": ["cloudtrail", "vpc_flow_logs", "guardduty", "s3_access_logs", "route53_logs"]
    },
    "logic": {
      "type": "object",
      "required": ["event_name", "conditions"],
      "properties": {
        "event_name": {
          "type": "string"
        },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["field", "operator", "value"],
            "properties": {
              "field": { "type": "string" },
              "operator": {
                "type": "string",
                "enum": [
                  "eq", "neq", "contains", "not_contains", "regex",
                  "gt", "lt", "gte", "lte", "in", "not_in",
                  "exists", "not_exists"
                ]
              },
              "value": {}
            }
          }
        },
        "aggregate": {
          "type": "object",
          "properties": {
            "group_by": { "type": "array", "items": { "type": "string" } },
            "count_threshold": { "type": "integer", "minimum": 1 },
            "time_window_minutes": { "type": "integer", "minimum": 1 }
          },
          "required": ["group_by", "count_threshold", "time_window_minutes"]
        }
      }
    },
    "false_positive_guidance": { "type": "string" },
    "references": {
      "type": "array",
      "items": { "type": "string" }
    },
    "response_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}